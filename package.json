{
	"name": "instafication-frontend",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"license": "MIT",
	"packageManager": "bun@1.3.13",
	"scripts": {
		"dev": "vite dev",
		"dev:wrangler": "drizzle-kit generate && vite build && wrangler dev",
		"build": "vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && biome check .",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "biome format --write .",
		"lint": "biome check .",
		"cf-typegen": "wrangler types ./src/worker-configuration.d.ts",
		"deploy": "bun run build && bun run cf-typegen && wrangler deploy",
		"generate": "drizzle-kit generate",
		"push": "drizzle-kit push",
		"migrate:prod": "drizzle-kit generate && wrangler d1 migrations apply prod --remote",
		"studio": "drizzle-kit studio",
		"logs": "wrangler tail frontend",
		"clean": "rm -rf .svelte-kit && rm -rf node_modules && rm -rf .wrangler && rm -rf .svelte-kit && rm -f bun.lock && rm -f package-lock.json && bun i"
	},
	"dependencies": {
		"@better-auth/utils": "^0.4.0",
		"@neondatabase/serverless": "^1.1.0",
		"@typescript/native-preview": "^7.0.0-dev.20260501.1",
		"better-auth": "^1.6.9",
		"better-auth-cloudflare": "^0.3.0",
		"clsx": "^2.1.1",
		"drizzle-orm": "1.0.0-beta.12-18d8bfb",
		"drizzle-valibot": "^0.4.2",
		"flowbite-svelte": "^1.33.1",
		"hash-wasm": "^4.12.0",
		"posthog-js": "^1.372.5",
		"posthog-node": "^5.32.0",
		"rou3": "0.8.1",
		"stripe": "^22.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"valibot": "^1.3.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.14.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@types/pg": "^8.20.0",
		"better-sqlite3": "^12.9.0",
		"bits-ui": "^2.18.0",
		"drizzle-kit": "1.0.0-beta.12-18d8bfb",
		"flowbite": "^4.0.1",
		"mode-watcher": "^1.1.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.7",
		"svelte-flag-icons": "^3.0.1",
		"svelte-sonner": "^1.1.1",
		"tailwindcss": "^4.2.4",
		"toml": "^4.1.1",
		"tw-animate-css": "^1.4.0",
		"vite": "8.0.10",
		"wrangler": "^4.87.0"
	}
}
